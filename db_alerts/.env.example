## Example environment variables for db_alerts service
# Copy to .env and fill values before running the service

# MongoDB connection URI (include credentials if using Atlas)
MONGO_URI=
MONGO_DB_NAME=kirana_ai
STORE_ID=store_001

# ElevenLabs TTS API key (optional for audio Vasooli)
ELEVENLABS_API_KEY=

# Twilio credentials for WhatsApp messaging
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+1415XXXXXXX

# Public base URL used to build audio asset URLs (e.g. https://yourdomain)
PUBLIC_BASE_URL=
